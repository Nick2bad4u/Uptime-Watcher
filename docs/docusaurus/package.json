{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "docs-docusaurus",
    "version": "1.0.0",
    "private": true,
    "description": "Documentation site for Uptime Watcher using Docusaurus",
    "keywords": [
        "docusaurus",
        "documentation",
        "uptime",
        "monitoring",
        "electron"
    ],
    "homepage": "https://nick2bad4u.github.io/Uptime-Watcher/",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/Uptime-Watcher/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/Uptime-Watcher-Docusaurus.git"
    },
    "license": "UNLICENSED",
    "author": "Nick2bad4u",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "scripts": {
        "build": "npm run generate-docs && cd ../../ && npm run build:eslint-inspector && cd docs/docusaurus && docusaurus build",
        "build:default": "docusaurus build",
        "build:fast": "cross-env DOCUSAURUS_ENABLE_EXPERIMENTAL=true docusaurus build",
        "build:local": "npm run generate-docs:local && cd ../../ && npm run build:eslint-inspector && cd docs/docusaurus && docusaurus build",
        "clear": "docusaurus clear",
        "css:types": "node -e \"const { run } = require('typed-css-modules/lib/run'); run('src', { pattern: '**/*.module.css' }).catch((error) => { console.error(error); process.exit(1); });\"",
        "css:types:check": "node -e \"const { run } = require('typed-css-modules/lib/run'); run('src', { listDifferent: true, pattern: '**/*.module.css' }).catch((error) => { console.error(error); process.exit(1); });\"",
        "deploy": "docusaurus deploy",
        "docusaurus": "docusaurus",
        "generate-docs": "npm run generate-docs:default",
        "generate-docs:app": "typedoc --options ../../typedoc.json",
        "generate-docs:default": "node ../../scripts/run-typedoc-safe.mjs docs/docusaurus/typedoc.config.json",
        "generate-docs:electron": "typedoc --options ../../typedoc.electron.json",
        "generate-docs:local": "node ../../scripts/run-typedoc-safe.mjs docs/docusaurus/typedoc.local.config.json",
        "lint": "cd ../../ && eslint --cache docs/docusaurus",
        "lint:css": "stylelint . --cache --config ../../stylelint.config.mjs --ignore-path .stylelintignore --cache-strategy content --cache-location stylelintcache --formatter=verbose",
        "lint:css:fix": "stylelint . --cache --config ../../stylelint.config.mjs --ignore-path .stylelintignore --cache-strategy content --cache-location stylelintcache --formatter=verbose --fix",
        "lint:fix": "cd ../../ && eslint --cache docs/docusaurus --fix",
        "serve": "docusaurus serve",
        "start": "docusaurus start",
        "swizzle": "docusaurus swizzle",
        "type-check": "npm run typecheck",
        "typecheck": "npm run typecheck:build && npm run css:types:check",
        "typecheck:build": "tsc --project tsconfig.json --noEmit",
        "write-heading-ids": "docusaurus write-heading-ids",
        "write-translations": "docusaurus write-translations"
    },
    "dependencies": {
        "@docusaurus/core": "^3.10.1",
        "@docusaurus/faster": "^3.10.1",
        "@docusaurus/plugin-content-docs": "^3.10.1",
        "@docusaurus/plugin-pwa": "^3.10.1",
        "@docusaurus/preset-classic": "^3.10.1",
        "@docusaurus/theme-live-codeblock": "^3.10.1",
        "@docusaurus/theme-mermaid": "^3.10.1",
        "@docusaurus/theme-search-algolia": "^3.10.1",
        "@docusaurus/types": "^3.10.1",
        "@easyops-cn/docusaurus-search-local": "^0.55.1",
        "@eslint/config-inspector": "^2.0.0",
        "@mdx-js/react": "^3.1.1",
        "clsx": "^2.1.1",
        "docusaurus-plugin-copy-page-button": "^0.5.0",
        "docusaurus-plugin-image-zoom": "^3.0.1",
        "docusaurus-plugin-llms": "^0.4.0",
        "docusaurus-plugin-typedoc": "^1.4.2",
        "prism-react-renderer": "^2.4.1",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-github-btn": "^1.4.0"
    },
    "devDependencies": {
        "@docusaurus/eslint-plugin": "^3.10.1",
        "@docusaurus/module-type-aliases": "^3.10.1",
        "@docusaurus/tsconfig": "^3.10.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "cross-env": "^10.1.0",
        "typed-css-modules": "^0.9.1",
        "typedoc": "^0.28.19",
        "typedoc-plugin-coverage": "^4.0.3",
        "typedoc-plugin-dt-links": "^2.0.53",
        "typedoc-plugin-external-package-links": "^0.2.0",
        "typedoc-plugin-markdown": "^4.11.0",
        "typedoc-plugin-mdn-links": "^5.1.1",
        "typedoc-plugin-missing-exports": "^4.1.3",
        "typedoc-plugin-remark": "^2.0.1",
        "typedoc-plugin-rename-defaults": "^0.7.3",
        "typedoc-plugin-replace-text": "^4.2.0",
        "typescript": "^6.0.3"
    },
    "engines": {
        "node": ">=18.0"
    },
    "preferGlobal": false
}
